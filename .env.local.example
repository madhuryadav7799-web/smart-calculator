# YouTube Automation Configuration
# Fill in your actual keys and rename to .env.local

# YouTube API Key (from Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ElevenLabs API Key (from elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# YouTube Channel ID (optional, for direct uploads)
YOUTUBE_CHANNEL_ID=your_channel_id_here

# Content Settings
CONTENT_LANGUAGE=en-US
CONTENT_CATEGORY=tech
SHORTS_DURATION=30
DAILY_UPLOADS=3

# Schedule (in HH:MM format, 24-hour)
SCHEDULE_TIME_1=08:00
SCHEDULE_TIME_2=13:00
SCHEDULE_TIME_3=18:00

# Voice Settings
VOICE_NAME=Nova
VOICE_STABILITY=0.75
VOICE_SIMILARITY=0.75
