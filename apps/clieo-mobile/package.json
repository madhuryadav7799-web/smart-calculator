{
  "name": "clieo-mobile",
  "version": "2.0.0",
  "description": "Clieo 2.0 Mobile App - Status & Agent Control",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild": "expo prebuild --clean",
    "build:apk": "npm run prebuild && cd android && ./gradlew assembleDebug",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/hooks": "^3.0.0",
    "axios": "^1.7.4",
    "expo": "^52.0.0",
    "expo-build-properties": "^55.0.10",
    "expo-router": "^3.5.0",
    "expo-status-bar": "^1.12.1",
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "^3.31.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.3.0"
  },
  "expo": {
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "targetSdkVersion": 34
          }
        }
      ]
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
